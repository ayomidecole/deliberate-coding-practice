{
  "name": "deliberate-coding-practice",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run --exclude 'exercises/typescript/003-repair-inventory-reservation/**'",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:go": "go test ./...",
    "check:typescript": "npm run typecheck && npm test",
    "check:go": "go vet ./... && go test ./...",
    "check": "npm run check:typescript && npm run check:go"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
